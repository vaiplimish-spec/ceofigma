      <div class="role-item"><div class="role-label">Инструменты</div><div class="role-val">Figma · Photoshop</div></div>
      <div class="role-item"><div class="role-label">Behance</div><div class="role-val"><a href="https://www.behance.net/gallery/173628561/Simpol-Wallet-App-Product-Case" target="_blank" style="color:var(--c);text-decoration:none;border-bottom:1px solid rgba(200,200,208,.3);">Открыть кейс →</a></div></div>
