.hero-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--c);margin-bottom:24px;display:flex;align-items:center;gap:12px;opacity:0;animation:fadeUp .8s .2s forwards}
.hero-tag::before{content:'';width:32px;height:1px;background:var(--c)}
.hero-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(52px,7vw,100px);line-height:.88;letter-spacing:-4px;margin-bottom:40px;opacity:0;animation:fadeUp .8s .3s forwards}
.hero-title span{color:var(--c)}
.hero-meta{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);max-width:700px;opacity:0;animation:fadeUp .8s .5s forwards}
.meta-cell{background:var(--bg);padding:24px 28px}
.meta-label{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.meta-val{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--text)}
section{padding:100px 60px;position:relative}
.section-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;display:flex;align-items:center;gap:12px}
.section-tag::before{content:'';width:32px;height:1px;background:var(--accent)}
.section-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(30px,3.5vw,44px);letter-spacing:-2px;margin-bottom:48px}
.overview{border-top:1px solid var(--border);background:var(--surface)}
.ov-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px}
.ov-text{font-size:13px;line-height:2;color:var(--muted)}
.ov-text p+p{margin-top:16px}
.ov-text strong{color:var(--text);font-weight:400}
.roles{display:flex;flex-direction:column}
.role-item{border-top:1px solid var(--border);padding:20px 0;display:grid;grid-template-columns:120px 1fr;gap:20px}
.role-item:last-child{border-bottom:1px solid var(--border)}
.role-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding-top:2px}
.role-val{font-size:13px;color:var(--text);line-height:1.6}
.colors-section{border-top:1px solid var(--border)}
.colors-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border)}
.color-card{background:var(--card);padding:28px 24px}
.color-swatch{height:60px;border-radius:4px;margin-bottom:14px}
.color-hex{font-size:12px;color:var(--text);margin-bottom:4px;letter-spacing:.05em}
.color-name{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.typo-section{border-top:1px solid var(--border);background:var(--surface)}
.typo-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border)}
.typo-block{background:var(--card);padding:40px 36px}
.typo-label{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:20px}
.typo-display{font-size:32px;font-weight:700;line-height:1.1;margin-bottom:14px}
.typo-meta{font-size:11px;color:var(--muted);line-height:2}
.stats-section{border-top:1px solid var(--border)}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.stat-cell{background:var(--card);padding:48px 36px;position:relative}
.stat-cell::after{content:'';position:absolute;bottom:0;left:36px;right:36px;height:2px;background:var(--c);opacity:.25}
.stat-num{font-family:'Syne',sans-serif;font-size:52px;font-weight:800;letter-spacing:-2px;color:var(--c);line-height:1;margin-bottom:10px}
.stat-lbl{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.back-cta{border-top:1px solid var(--border);padding:80px 60px;text-align:center;background:var(--surface)}
.back-cta h2{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;letter-spacing:-2px;margin-bottom:32px}
.back-cta h2 em{font-style:italic;font-family:'Instrument Serif',serif;color:var(--accent)}
.btn-group{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.back-btn{display:inline-block;background:var(--accent);color:var(--bg);padding:16px 40px;font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .2s}
.back-btn:hover{background:#d4f570;transform:translateY(-2px)}
.ext-btn{display:inline-block;border:1px solid var(--c);color:var(--c);padding:16px 40px;font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .2s}
.ext-btn:hover{background:rgba(0,198,94,.08)}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border)}
@media(max-width:900px){
  nav{padding:20px 24px}section{padding:72px 24px}.hero{padding:120px 24px 60px}
  .ov-grid{grid-template-columns:1fr}.typo-grid{grid-template-columns:1fr}
  .hero-meta{grid-template-columns:1fr 1fr}.colors-grid{grid-template-columns:1fr 1fr 1fr}
