<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080a0f;
  --surface:#0d1017;
  --border:rgba(255,255,255,0.07);
  --accent:#c8f05a;
  --text:#e8eaf0;
  --muted:#5a6070;
  --card:#0f1318;
  --repay-blue:#6366f1;
  --repay-light:#60a5fa;
  --repay-dark:#1e293b;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Mono',monospace;overflow-x:hidden;cursor:none}

.cursor{width:12px;height:12px;background:var(--accent);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;mix-blend-mode:difference}
.cursor-ring{width:36px;height:36px;border:1px solid rgba(200,240,90,0.4);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transition:transform 0.32s cubic-bezier(.17,.67,.35,1.2)}

body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:.35}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;padding:20px 60px;display:flex;align-items:center;justify-content:space-between;z-index:100;border-bottom:1px solid var(--border);background:rgba(8,10,15,0.9);backdrop-filter:blur(20px)}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--text);text-decoration:none}
.nav-logo span{color:var(--accent)}
.nav-back{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:8px;transition:color .2s}
.nav-back:hover{color:var(--accent)}
.nav-back::before{content:'←'}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:160px 60px 80px;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(99,102,241,0.12) 0%,transparent 70%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(99,102,241,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.04) 1px,transparent 1px);background-size:60px 60px}

/* RePay logo SVG recreation */
.hero-logo{margin-bottom:48px;opacity:0;animation:fadeUp .8s .1s forwards}
.hero-logo svg{width:180px;height:60px}

.hero-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--repay-blue);margin-bottom:24px;display:flex;align-items:center;gap:12px;opacity:0;animation:fadeUp .8s .2s forwards}
.hero-tag::before{content:'';width:32px;height:1px;background:var(--repay-blue)}
.hero-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(52px,7vw,100px);line-height:.88;letter-spacing:-4px;margin-bottom:40px;opacity:0;animation:fadeUp .8s .3s forwards}
.hero-title em{font-style:italic;font-family:'Instrument Serif',serif;color:var(--repay-blue)}

.hero-meta{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);max-width:700px;opacity:0;animation:fadeUp .8s .5s forwards}
.meta-cell{background:var(--bg);padding:24px 28px}
.meta-label{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.meta-val{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--text)}

@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

/* SECTIONS */
section{padding:120px 60px;position:relative}
.section-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;display:flex;align-items:center;gap:12px}
.section-tag::before{content:'';width:32px;height:1px;background:var(--accent)}
.section-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(32px,3.5vw,48px);letter-spacing:-2px;margin-bottom:48px}

/* OVERVIEW */
.overview{border-top:1px solid var(--border);background:var(--surface)}
.overview-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.overview-text{font-size:13px;line-height:2;color:var(--muted)}
.overview-text p+p{margin-top:20px}
.overview-text strong{color:var(--text);font-weight:400}
.roles{display:flex;flex-direction:column;gap:1px}
.role-item{border-top:1px solid var(--border);padding:20px 0;display:grid;grid-template-columns:140px 1fr;gap:20px}
.role-item:last-child{border-bottom:1px solid var(--border)}
.role-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding-top:2px}
.role-val{font-size:13px;color:var(--text)}

/* UI KIT */
.uikit{border-top:1px solid var(--border)}
.uikit-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--border)}
.kit-block{background:var(--card);padding:36px}
.kit-title{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:24px}

/* Colors */
.colors-row{display:flex;gap:8px;flex-wrap:wrap}
.color-chip{display:flex;flex-direction:column;gap:8px;align-items:center}
.chip-swatch{width:48px;height:48px;border-radius:4px}
.chip-label{font-size:9px;color:var(--muted);text-align:center;letter-spacing:.04em}

/* Typography */
.type-sample{margin-bottom:16px}
.type-name{font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.type-display{font-size:22px;font-weight:700;color:var(--text);font-family:'Inter','DM Mono',sans-serif;letter-spacing:-.5px}
.type-body{font-size:13px;color:var(--muted);line-height:1.6;font-family:'Inter','DM Mono',sans-serif}
.type-mono{font-size:11px;color:var(--repay-blue);font-family:'DM Mono',monospace;letter-spacing:.05em}

/* Components */
.comp-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;align-items:center}
.badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:10px;letter-spacing:.06em}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0}
.badge-green{background:rgba(34,197,94,.12);color:#22c55e}.badge-green::before{background:#22c55e}
.badge-red{background:rgba(239,68,68,.12);color:#ef4444}.badge-red::before{background:#ef4444}
.badge-yellow{background:rgba(234,179,8,.12);color:#eab308}.badge-yellow::before{background:#eab308}
.badge-gray{background:rgba(100,116,139,.12);color:#64748b}.badge-gray::before{background:#64748b}

.btn-primary-demo{background:linear-gradient(135deg,var(--repay-blue),var(--repay-light));color:white;border:none;padding:9px 20px;border-radius:8px;font-size:11px;letter-spacing:.06em;cursor:pointer}
.btn-ghost-demo{background:transparent;color:var(--repay-blue);border:1px solid rgba(99,102,241,.3);padding:9px 20px;border-radius:8px;font-size:11px;letter-spacing:.06em;cursor:pointer}
.input-demo{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:8px 14px;font-size:11px;color:#334155;width:100%;font-family:inherit}
.progress-demo{height:4px;background:#e2e8f0;border-radius:2px;overflow:hidden;margin-bottom:4px}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--repay-blue),var(--repay-light));border-radius:2px}

/* SCREENS */
.screens{border-top:1px solid var(--border);background:var(--surface)}
.screens-intro{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-bottom:80px}
.screen-section{margin-bottom:80px}
.screen-section-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;letter-spacing:-.5px;margin-bottom:8px}
.screen-section-sub{font-size:12px;color:var(--muted);line-height:1.8;margin-bottom:32px}

/* Monitor mockup */
.monitor-wrap{position:relative;margin-bottom:48px}
.monitor{background:#1a2035;border-radius:12px;border:1px solid rgba(255,255,255,.08);padding:8px;box-shadow:0 40px 80px rgba(0,0,0,.6),0 0 0 1px rgba(99,102,241,.1),0 20px 40px rgba(99,102,241,.08);position:relative}
.monitor::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(99,102,241,.4),transparent);border-radius:12px 12px 0 0}
.monitor-screen{border-radius:6px;overflow:hidden;width:100%;background:#f8fafc;position:relative}
.monitor-screen img{width:100%;height:auto;display:block;object-fit:cover}
.monitor-neck{width:20px;height:18px;background:#111827;margin:0 auto}
.monitor-base{width:120px;height:8px;background:linear-gradient(90deg,#0a0f1a,#1a2035,#0a0f1a);margin:0 auto;border-radius:4px;border:1px solid rgba(255,255,255,.05)}

/* Phone mockup */
.phone-wrap{position:relative;display:inline-block}
.phone{background:#1a2035;border-radius:36px;border:1px solid rgba(255,255,255,.1);padding:10px;box-shadow:0 40px 80px rgba(0,0,0,.6),0 0 0 1px rgba(99,102,241,.1);position:relative;max-width:260px;margin:0 auto;display:block}
.phone-notch{width:80px;height:20px;background:#111827;border-radius:0 0 14px 14px;margin:0 auto 6px;position:relative}
.phone-notch::before{content:'';position:absolute;width:10px;height:10px;background:#0d1117;border-radius:50%;top:4px;left:50%;transform:translateX(-50%)}
.phone-screen{border-radius:28px;overflow:hidden;background:white}
.phone-screen img{width:100%;display:block}
.phone-home{width:100px;height:4px;background:rgba(255,255,255,.2);border-radius:2px;margin:8px auto 0}

/* Two-col screens */
.screens-2col{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:32px}
.screens-3col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;margin-bottom:32px}

/* Label under screen */
.screen-label{margin-top:12px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-align:center}

/* Mobile+desktop combo */
.combo-layout{display:grid;grid-template-columns:1fr 280px;gap:48px;align-items:center}

/* HIGHLIGHT CARD */
.highlight{border:1px solid var(--border);padding:48px;margin-bottom:32px;position:relative;overflow:hidden}
.highlight::before{content:'';position:absolute;top:0;left:0;bottom:0;width:2px;background:linear-gradient(180deg,var(--repay-blue),var(--repay-light))}
.highlight-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:12px}
.highlight-text{font-size:12px;line-height:1.9;color:var(--muted)}

/* RESULTS */
.results{border-top:1px solid var(--border)}
.results-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.result-cell{background:var(--card);padding:48px 36px;position:relative;overflow:hidden}
.result-cell::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--repay-blue),var(--repay-light));transform:scaleX(0);transform-origin:left;transition:transform .4s}
.result-cell:hover::after{transform:scaleX(1)}
.result-num{font-family:'Syne',sans-serif;font-size:52px;font-weight:800;line-height:1;letter-spacing:-2px;background:linear-gradient(135deg,var(--repay-blue),var(--repay-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:10px}
.result-label{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}

/* BACK CTA */
.back-cta{border-top:1px solid var(--border);padding:80px 60px;text-align:center;background:var(--surface)}
.back-cta h2{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;letter-spacing:-2px;margin-bottom:24px}
.back-cta h2 em{font-style:italic;font-family:'Instrument Serif',serif;color:var(--accent)}
.back-btn{display:inline-block;background:var(--accent);color:var(--bg);padding:16px 40px;font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .2s;margin-top:8px}
.back-btn:hover{background:#d4f570;transform:translateY(-2px)}

/* Reveal */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* Scrollbar */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--muted)}
::-webkit-scrollbar-thumb:hover{background:var(--repay-blue)}

@media(max-width:900px){
  nav{padding:20px 24px}
  section{padding:80px 24px}
  .hero{padding:120px 24px 60px}
  .overview-grid,.screens-intro,.combo-layout{grid-template-columns:1fr}
  .uikit-grid{grid-template-columns:1fr}
  .screens-2col,.screens-3col{grid-template-columns:1fr}
  .results-grid{grid-template-columns:1fr 1fr!important}
  .hero-meta{grid-template-columns:1fr 1fr}
  .back-cta{padding:60px 24px}
  .back-cta h2{font-size:36px}
}
</style>
</head>
