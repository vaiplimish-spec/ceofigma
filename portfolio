      <div class="role-item"><div class="role-label">Формат</div><div class="role-val">Web · Desktop · Adaptive</div></div>
      <div class="role-item"><div class="role-label">Инструменты</div><div class="role-val">Figma · Photoshop</div></div>
      <div class="role-item"><div class="role-label">Behance</div><div class="role-val"><a href="https://www.behance.net/gallery/162252379/AGC-BURYA-UIUX-DESIGN" target="_blank" style="color:var(--c);text-decoration:none;border-bottom:1px solid rgba(0,198,94,.3);">Открыть кейс →</a></div></div>
    </div>
  </div>
</section>

<section class="colors-section">
  <div class="section-tag reveal">Visual Identity</div>
  <h2 class="section-title reveal">Цвета</h2>
  <div class="colors-grid reveal">
    <div class="color-card">
      <div class="color-swatch" style="background:#00C65E"></div>
      <div class="color-hex">#00C65E</div>
      <div class="color-name">Primary Green</div>
    </div>
<div class="color-card">
      <div class="color-swatch" style="background:#000000;border:1px solid rgba(255,255,255,0.08)"></div>
